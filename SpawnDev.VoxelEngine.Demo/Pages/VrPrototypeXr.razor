@page "/vr-prototype-xr"
@using SpawnDev.BlazorJS
@using SpawnDev.BlazorJS.JSObjects
@using SpawnDev.VoxelEngine.Rendering
@implements IAsyncDisposable

<PageTitle>VR Prototype XR - Hybrid (WebGPU + XRWebGLLayer)</PageTitle>

<h3>VR Prototype - Hybrid WebXR + WebGL2 + WebGPU compute (Phase VR.1c)</h3>

<p>
    The actual Lost Spawns v1 Quest shipping architecture:
    <strong>WebGPU</strong> renders an animated spiral pattern to an <code>OffscreenCanvas</code>,
    <strong>WebGL2</strong> uploads the canvas directly via <code>texImage2D(canvas)</code> (proven bridge
    from VR.1a), and the WebGL2 context is attached to the XR session as the
    <strong>XRWebGLLayer</strong> base layer (the proven 90fps path on Quest).
    Per frame, each eye gets the texture rendered as a fullscreen quad into the XR framebuffer's
    per-eye viewport. Not stereoscopic yet - both eyes see the same 2D pattern - but the plumbing
    is what Lost Spawns' actual 3D scene will slot into.
</p>

@if (_report != null)
{
    <p>Capability: <code style="color:@PathColor(_report.Path)">@_report.Path</code></p>
}

<div style="margin:12px 0;">
    @if (_sessionActive)
    {
        <button @onclick="ExitVrAsync">Exit VR</button>
    }
    else
    {
        <button @onclick="EnterVrAsync" disabled="@(_starting || _report == null || !_report.HasImmersiveVr)">
            @(_starting ? "Starting VR session..." : (_report?.HasImmersiveVr == true ? "Enter VR" : "VR not available"))
        </button>
    }
</div>

@if (!string.IsNullOrEmpty(_errorMessage))
{
    <pre style="color:#ef4444;white-space:pre-wrap;">@_errorMessage</pre>
}

<div style="display:flex;gap:16px;flex-wrap:wrap;">
    <div>
        <div style="color:#888;font-size:0.85em;">WebGL2 context (XR-compatible; drives the XRWebGLLayer framebuffer in VR)</div>
        <canvas id="vr-proto-xr-canvas" width="1024" height="512"
                style="width:512px;height:256px;background:#111;border:1px solid #444;"></canvas>
    </div>

    <div style="font-family:monospace;background:#1e1e1e;color:#d4d4d4;padding:12px;border:1px solid #444;min-width:340px;">
        <div style="color:#4ade80;font-weight:bold;">XR session state</div>
        <div>Session active : <span style="color:@(_sessionActive ? "#4ade80" : "#888")">@_sessionActive</span></div>
        <div>Enabled features: @(_enabledFeatures == null ? "(none)" : string.Join(", ", _enabledFeatures))</div>
        <div>Frames rendered: @_frameCount</div>
        <div>Views per frame: @_viewsPerFrame</div>
        <div>Framebuffer dim: @_framebufferDim</div>
        <div>Reference space: @(_refSpaceTypeLabel ?? "(none)")</div>
    </div>
</div>

@inject BlazorJSRuntime JS

@code {
    RenderPathReport? _report;

    // WebGPU
    GPUAdapter? _adapter;
    GPUDevice? _device;
    GPUShaderModule? _shader;
    GPURenderPipeline? _pipeline;
    GPUBindGroup? _bindGroup;
    GPUBuffer? _paramsBuffer;
    OffscreenCanvas? _offscreen;
    GPUCanvasContext? _offscreenCtx;

    // WebGL2 + XR
    HTMLCanvasElement? _canvas;
    WebGL2RenderingContext? _gl;
    WebGLProgram? _glProgram;
    WebGLTexture? _glTexture;

    XRSession? _session;
    XRWebGLLayer? _xrLayer;
    XRReferenceSpace? _refSpace;
    string? _refSpaceTypeLabel;
    string[]? _enabledFeatures;

    bool _sessionActive;
    bool _starting;
    int _frameCount;
    int _viewsPerFrame;
    string _framebufferDim = "--";
    string? _errorMessage;

    const int OffscreenSize = 512;
    const string CanvasFormat = "bgra8unorm";

    const string ShaderWgsl = @"
struct Params {
  time : f32,
  _pad0 : f32,
  _pad1 : f32,
  _pad2 : f32,
}
@group(0) @binding(0) var<uniform> params : Params;

struct VOut {
  @builtin(position) pos : vec4<f32>,
  @location(0) uv : vec2<f32>,
}

@vertex
fn vs(@builtin(vertex_index) i : u32) -> VOut {
  var p = array<vec2<f32>, 3>(
    vec2<f32>(-1.0, -1.0),
    vec2<f32>( 3.0, -1.0),
    vec2<f32>(-1.0,  3.0),
  );
  var uv = array<vec2<f32>, 3>(
    vec2<f32>(0.0, 1.0),
    vec2<f32>(2.0, 1.0),
    vec2<f32>(0.0, -1.0),
  );
  var o : VOut;
  o.pos = vec4<f32>(p[i], 0.0, 1.0);
  o.uv = uv[i];
  return o;
}

@fragment
fn fs(@location(0) uv : vec2<f32>) -> @location(0) vec4<f32> {
  let t = params.time;
  let d = uv - vec2<f32>(0.5, 0.5);
  let dist = length(d);
  let angle = atan2(d.y, d.x);
  let r = sin(dist * 20.0 - t * 2.0) * 0.5 + 0.5;
  let g = sin(angle * 4.0 + t) * 0.5 + 0.5;
  let b = cos(dist * 15.0 + t * 1.5) * 0.5 + 0.5;
  return vec4<f32>(r, g, b, 1.0);
}
";

    const string GlVertSrc = @"#version 300 es
out vec2 v_uv;
void main() {
  vec2 p = vec2((gl_VertexID << 1) & 2, gl_VertexID & 2);
  v_uv = p;
  gl_Position = vec4(p * 2.0 - 1.0, 0.0, 1.0);
}
";

    const string GlFragSrc = @"#version 300 es
precision mediump float;
in vec2 v_uv;
uniform sampler2D u_tex;
out vec4 out_color;
void main() {
  out_color = texture(u_tex, vec2(v_uv.x, 1.0 - v_uv.y));
}
";

    protected override async Task OnInitializedAsync()
    {
        _report = await RenderPathDetector.DetectAsync(JS);
    }

    async Task EnterVrAsync()
    {
        if (_sessionActive || _starting) return;
        _starting = true;
        _errorMessage = null;
        StateHasChanged();

        try
        {
            using var nav = new Navigator();
            using var gpu = nav.Gpu ?? throw new InvalidOperationException("navigator.gpu unavailable");
            using var xr = nav.XR ?? throw new InvalidOperationException("navigator.xr unavailable");

            // WebGPU device + offscreen canvas for scene rendering.
            _adapter = await gpu.RequestAdapter() ?? throw new InvalidOperationException("no adapter");
            _device = await _adapter.RequestDevice();

            _offscreen = new OffscreenCanvas(OffscreenSize, OffscreenSize);
            _offscreenCtx = _offscreen.GetWebGPUContext() ?? throw new InvalidOperationException("offscreen webgpu context null");
            _offscreenCtx.Configure(new GPUCanvasConfiguration
            {
                Device = _device,
                Format = CanvasFormat,
                AlphaMode = "premultiplied",
            });

            _paramsBuffer = _device.CreateBuffer(new GPUBufferDescriptor
            {
                Size = 16,
                Usage = GPUBufferUsage.Uniform | GPUBufferUsage.CopyDst,
            });
            _shader = _device.CreateShaderModule(new GPUShaderModuleDescriptor { Code = ShaderWgsl });
            _pipeline = _device.CreateRenderPipeline(new GPURenderPipelineDescriptor
            {
                Layout = "auto",
                Vertex = new GPUVertexState { Module = _shader, EntryPoint = "vs" },
                Fragment = new GPUFragmentState
                {
                    Module = _shader,
                    EntryPoint = "fs",
                    Targets = new[] { new GPUColorTargetState { Format = CanvasFormat } },
                },
                Primitive = new GPUPrimitiveState { Topology = GPUPrimitiveTopology.TriangleList },
            });
            _bindGroup = _device.CreateBindGroup(new GPUBindGroupDescriptor
            {
                Layout = _pipeline.GetBindGroupLayout(0),
                Entries = new GPUBindGroupEntry[]
                {
                    new() { Binding = 0, Resource = new GPUBufferBinding { Buffer = _paramsBuffer } },
                },
            });

            // WebGL2 context with xrCompatible attribute. This is the context that XRWebGLLayer
            // will render into; the WebXR compositor picks up its framebuffer.
            using var doc = JS.Get<Document>("document");
            _canvas = doc.GetElementById<HTMLCanvasElement>("vr-proto-xr-canvas")
                ?? throw new InvalidOperationException("canvas not found");
            _gl = _canvas.GetContext<WebGL2RenderingContext>("webgl2", new WebGLContextAttributes
            {
                XrCompatible = true,
            }) ?? throw new InvalidOperationException("webgl2 context null");

            SetupGlProgramAndTexture();

            // Request the XR session (plain - no 'webgpu' feature needed for this path).
            var init = new XRSessionInit
            {
                RequiredFeatures = new[] { "local" },
                OptionalFeatures = new[] { "local-floor" },
            };
            _session = await xr.RequestSession(XRSessionMode.ImmersiveVR, init);
            try { _enabledFeatures = _session.EnabledFeatures; } catch { _enabledFeatures = null; }

            // Create the XR layer with our WebGL2 context + attach as base layer.
            _xrLayer = new XRWebGLLayer(_session, _gl);
            _framebufferDim = $"{_xrLayer.FramebufferWidth} x {_xrLayer.FramebufferHeight}";
            _session.UpdateRenderState(new XRRenderStateInit { BaseLayer = _xrLayer });

            try
            {
                _refSpace = await _session.RequestReferenceSpace(XRReferenceSpaceType.LocalFloor);
                _refSpaceTypeLabel = "local-floor";
            }
            catch
            {
                _refSpace = await _session.RequestReferenceSpace(XRReferenceSpaceType.Local);
                _refSpaceTypeLabel = "local";
            }

            _session.OnEnd += OnSessionEnd;
            _sessionActive = true;
            _frameCount = 0;
            _session.RequestAnimationFrame(OnXrFrame);
        }
        catch (Exception ex)
        {
            _errorMessage = $"Enter VR failed: {ex.GetType().Name}: {ex.Message}\n{ex.StackTrace}";
            await CleanupAsync();
        }
        finally
        {
            _starting = false;
            StateHasChanged();
        }
    }

    void SetupGlProgramAndTexture()
    {
        if (_gl == null) return;

        using var vert = _gl.CreateShader(GL.VERTEX_SHADER);
        _gl.ShaderSource(vert, GlVertSrc);
        _gl.CompileShader(vert);
        if (!_gl.GetShaderParameter<bool>(vert, GL.COMPILE_STATUS))
            throw new InvalidOperationException("Vertex shader: " + _gl.GetShaderInfoLog(vert));

        using var frag = _gl.CreateShader(GL.FRAGMENT_SHADER);
        _gl.ShaderSource(frag, GlFragSrc);
        _gl.CompileShader(frag);
        if (!_gl.GetShaderParameter<bool>(frag, GL.COMPILE_STATUS))
            throw new InvalidOperationException("Fragment shader: " + _gl.GetShaderInfoLog(frag));

        _glProgram = _gl.CreateProgram();
        _gl.AttachShader(_glProgram, vert);
        _gl.AttachShader(_glProgram, frag);
        _gl.LinkProgram(_glProgram);
        if (!_gl.GetProgramParameter<bool>(_glProgram, GL.LINK_STATUS))
            throw new InvalidOperationException("Link: " + _gl.GetProgramInfoLog(_glProgram));

        _glTexture = _gl.CreateTexture();
        _gl.BindTexture(GL.TEXTURE_2D, _glTexture);
        _gl.TexParameteri(GL.TEXTURE_2D, GL.TEXTURE_MIN_FILTER, (int)GL.LINEAR);
        _gl.TexParameteri(GL.TEXTURE_2D, GL.TEXTURE_MAG_FILTER, (int)GL.LINEAR);
        _gl.TexParameteri(GL.TEXTURE_2D, GL.TEXTURE_WRAP_S, (int)GL.CLAMP_TO_EDGE);
        _gl.TexParameteri(GL.TEXTURE_2D, GL.TEXTURE_WRAP_T, (int)GL.CLAMP_TO_EDGE);

        _gl.UseProgram(_glProgram);
        using var texLoc = _gl.GetUniformLocation(_glProgram, "u_tex");
        if (texLoc != null) _gl.Uniform1i(texLoc, 0);
    }

    void OnXrFrame(double time, XRFrame? frame)
    {
        if (!_sessionActive || frame == null || _session == null || _refSpace == null
            || _device == null || _gl == null || _xrLayer == null)
        {
            return;
        }

        try
        {
            // Re-register immediately so we don't lose the slot if rendering throws.
            _session.RequestAnimationFrame(OnXrFrame);

            using var pose = frame.GetViewerPose(_refSpace);
            if (pose == null) return;

            // 1. Upload params, render spiral pattern to the OffscreenCanvas via WebGPU.
            var bytes = new byte[16];
            BitConverter.TryWriteBytes(bytes.AsSpan(0, 4), (float)(time / 1000.0));
            using (var u8 = new Uint8Array(bytes))
            {
                _device.Queue.WriteBuffer(_paramsBuffer!, 0, u8);
            }
            using (var encoder = _device.CreateCommandEncoder())
            {
                using var curTex = _offscreenCtx!.GetCurrentTexture();
                using var curView = curTex.CreateView();
                using var rp = encoder.BeginRenderPass(new GPURenderPassDescriptor
                {
                    ColorAttachments = new[]
                    {
                        new GPURenderPassColorAttachment
                        {
                            View = curView, LoadOp = GPULoadOp.Clear, StoreOp = GPUStoreOp.Store,
                            ClearValue = new GPUColorDict { R = 0, G = 0, B = 0, A = 1 },
                        }
                    }
                });
                rp.SetPipeline(_pipeline!);
                rp.SetBindGroup(0, _bindGroup!);
                rp.Draw(3);
                rp.End();
                using var cmd = encoder.Finish();
                _device.Queue.Submit(new[] { cmd });
            }

            // 2. Bind the XR framebuffer so WebGL draws into the compositor's target.
            using var fb = _xrLayer.Framebuffer;
            _gl.JSRef!.CallVoid("bindFramebuffer", GL.FRAMEBUFFER, fb);

            // 3. Upload the OffscreenCanvas to our texture (GPU-GPU path).
            _gl.BindTexture(GL.TEXTURE_2D, _glTexture!);
            _gl.TexImage2D(GL.TEXTURE_2D, 0, (int)GL.RGBA, GL.RGBA, GL.UNSIGNED_BYTE, _offscreen!);

            // 4. Draw the fullscreen textured quad once per eye viewport.
            _gl.UseProgram(_glProgram!);
            _gl.ActiveTexture(GL.TEXTURE0);
            _gl.BindTexture(GL.TEXTURE_2D, _glTexture!);

            int viewCount = 0;
            foreach (var view in pose.Views)
            {
                using (view)
                {
                    using var vp = _xrLayer.GetViewport(view);
                    _gl.Viewport(vp.X, vp.Y, vp.Width, vp.Height);
                    _gl.DrawArrays(GL.TRIANGLES, 0, 3);
                    viewCount++;
                }
            }
            _viewsPerFrame = viewCount;
            _frameCount++;

            if (_frameCount % 30 == 0) InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            _errorMessage = $"Frame {_frameCount}: {ex.GetType().Name}: {ex.Message}";
            InvokeAsync(StateHasChanged);
        }
    }

    void OnSessionEnd(XRSessionEvent e)
    {
        _sessionActive = false;
        _ = CleanupAsync();
        InvokeAsync(StateHasChanged);
    }

    async Task ExitVrAsync()
    {
        if (_session != null)
        {
            try { await _session.End(); }
            catch (Exception ex) { _errorMessage = $"Exit: {ex.Message}"; }
        }
    }

    async Task CleanupAsync()
    {
        if (_session != null)
        {
            try { _session.OnEnd -= OnSessionEnd; } catch { }
        }
        _xrLayer?.Dispose(); _xrLayer = null;
        _refSpace?.Dispose(); _refSpace = null;
        _session?.Dispose(); _session = null;
        _sessionActive = false;
        _refSpaceTypeLabel = null;

        _glTexture?.Dispose(); _glTexture = null;
        _glProgram?.Dispose(); _glProgram = null;
        _gl?.Dispose(); _gl = null;
        _canvas?.Dispose(); _canvas = null;

        _bindGroup?.Dispose(); _bindGroup = null;
        _pipeline?.Dispose(); _pipeline = null;
        _shader?.Dispose(); _shader = null;
        _paramsBuffer?.Dispose(); _paramsBuffer = null;
        _offscreenCtx?.Dispose(); _offscreenCtx = null;
        _offscreen?.Dispose(); _offscreen = null;

        _device?.Dispose(); _device = null;
        _adapter?.Dispose(); _adapter = null;

        await Task.CompletedTask;
    }

    public async ValueTask DisposeAsync()
    {
        _sessionActive = false;
        await CleanupAsync();
    }

    static string PathColor(RenderPath p) => p switch
    {
        RenderPath.FullWebGpu => "#4ade80",
        RenderPath.HybridWebGl2 => "#facc15",
        RenderPath.WebGpuOnly => "#60a5fa",
        RenderPath.None => "#ef4444",
        _ => "#888",
    };
}
